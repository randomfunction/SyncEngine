{
  "name": "crdt-backend",
  "version": "1.0.0",
  "description": "Realtime Collaborative CRDT Document Engine - Backend",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "npx prisma db push && node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "benchmark": "ts-node src/benchmark.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.13.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.26.2",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "uuid": "^9.0.1",
    "ws": "^8.16.0",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.14"
  },
  "devDependencies": {
    "@types/node": "^20.12.11",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "prisma": "^5.13.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
