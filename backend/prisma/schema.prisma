generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Append-only event store for CRDT operations
model Operation {
  id         String   @id @default(uuid())
  documentId String
  
  // Who generated this operation
  clientId   String   
  
  // The actual Yjs/CRDT binary update payload (Uint8Array base64 encoded)
  payload    Bytes    

  // Logical clock/sequence number to guarantee causal ordering
  clock      Int      

  createdAt  DateTime @default(now())

  @@index([documentId, clock])
}

// Compacted state to speed up document initialization
model Snapshot {
  id         String   @id @default(uuid())
  documentId String

  // The full binary state of the Yjs document at this point in time
  state      Bytes

  // The operation clock up to which this snapshot covers
  clock      Int

  createdAt  DateTime @default(now())

  @@index([documentId, clock(sort: Desc)])
}
